<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <Match>
    <Class name="org.betonquest.reposilite.mapper.settings.VersionMapperPluginSettings"/>
    <Method name="getArtifacts"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>
  <Match>
    <Class name="org.betonquest.reposilite.mapper.settings.VersionMapperPluginSettings"/>
    <Field name="artifacts"/>
    <Bug pattern="SE_BAD_FIELD"/>
  </Match>
  <Match>
    <Class name="org.betonquest.reposilite.mapper.settings.VersionMapperPluginSettings"/>
    <Field name="namingConventionWarning"/>
    <Bug pattern="SS_SHOULD_BE_STATIC"/>
  </Match>
  <Match>
    <Class name="org.betonquest.reposilite.mapper.settings.VersionMapperPluginSettings"/>
    <Field name="runExistenceChecks"/>
    <Bug pattern="SS_SHOULD_BE_STATIC"/>
  </Match>
  <Match>
    <Class name="org.betonquest.reposilite.api.validation.ValidationResult"/>
    <Method name="details"/>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>
  <Match>
    <Class name="org.betonquest.reposilite.api.validation.ValidationResult"/>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>
</FindBugsFilter>
